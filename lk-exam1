#!/bin/bash
# lk-exam1  Liu Kaitai  202314060402  2026-6-19

set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "错误：需要且仅需要一个正整数参数"
    echo -n "按任意键退出..."
    read -r -n 1
    exit 1
fi

if ! [[ "$1" =~ ^[1-9][0-9]*$ ]]; then
    echo "错误：参数必须是正整数"
    echo -n "按任意键退出..."
    read -r -n 1
    exit 1
fi

n="$1"
fruit="lemon"
target_dir="$HOME/lkgit"
created_files=()

cleanup() {
    if [[ ${#created_files[@]} -gt 0 ]]; then
        echo ""
        echo "正在清理本次创建的文件..."
        for f in "${created_files[@]}"; do
            if [[ -f "$target_dir/$f" ]]; then
                rm -f "$target_dir/$f"
                echo "  已删除: $f"
            fi
        done
    fi
}
trap cleanup EXIT INT TERM

echo "Liu Kaitai will create $n files"
cd "$target_dir" || exit 1

new_count=0
for ((i = 1; i <= n; i++)); do
    filename="${fruit}-${i}.MP3"
    if [[ -f "$filename" ]]; then
        echo "跳过已存在: $filename"
    else
        touch "$filename"
        created_files+=("$filename")
        echo "创建文件: $filename"
        ((new_count++))
    fi
done

echo ""
echo "Liu Kaitai fin"
echo "本次新创建的文件列表："
for f in "${created_files[@]}"; do
    echo "  $f"
done
echo "共创建 $new_count 个文件"
echo "当前时间: $(date '+%Y-%m-%d %H:%M:%S')"
echo -n "按任意键退出..."
read -r -n 1
echo ""
